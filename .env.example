# ── Forge — fill this in, then `npm start` ───────────────────────────────
# 1) Create a FREE Browserbase account → https://browserbase.com
# 2) Copy your API key + Project ID from Settings, paste below.

BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# The skill-training agents run on Claude. Add your own Anthropic API key here
# (https://console.anthropic.com).
ANTHROPIC_API_KEY=

# Optional: only set this if you route Anthropic calls through a custom endpoint.
# ANTHROPIC_BASE_URL=

# Optional: port for the local UI (default 4317)
PORT=4317
