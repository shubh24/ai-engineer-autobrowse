# ── Forge — fill this in, then `npm start` ───────────────────────────────
# 1) Create a FREE Browserbase account → https://browserbase.com
# 2) Copy your API key + Project ID from Settings, paste below.

BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# The skill-training agents run on Claude. For the workshop this is pre-set to
# the workshop proxy — leave it as-is. (Outside the workshop, drop your own
# Anthropic key here.)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Optional: port for the local UI (default 4317)
PORT=4317
